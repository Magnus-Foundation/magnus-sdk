{
  "name": "@magnus/sdk",
  "version": "0.1.1",
  "description": "JavaScript SDK for Magnus — chain definitions, type 0x76 transaction serializer, custom RPC actions, precompile ABIs, and locale-aware formatting",
  "license": "Apache-2.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./chain": {
      "types": "./dist/chain/index.d.ts",
      "import": "./dist/chain/index.mjs",
      "require": "./dist/chain/index.cjs"
    },
    "./transaction": {
      "types": "./dist/transaction/index.d.ts",
      "import": "./dist/transaction/index.mjs",
      "require": "./dist/transaction/index.cjs"
    },
    "./precompiles": {
      "types": "./dist/precompiles/index.d.ts",
      "import": "./dist/precompiles/index.mjs",
      "require": "./dist/precompiles/index.cjs"
    },
    "./rpc": {
      "types": "./dist/rpc/index.d.ts",
      "import": "./dist/rpc/index.mjs",
      "require": "./dist/rpc/index.cjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.mjs",
      "require": "./dist/utils/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "example:sign": "tsx examples/sign-and-decode.ts",
    "example:smoke": "tsx examples/smoke-broadcast.ts"
  },
  "peerDependencies": {
    "viem": "^2.20.0"
  },
  "pnpm": {"onlyBuiltDependencies": ["esbuild"]},
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0",
    "viem": "2.21.0",
    "vitest": "^2.1.0"
  }
}
